###############################################################################
# CommentCustomer.ai — Environment Variables
###############################################################################
# Copy this file to `.env` (Vercel/Render/Railway: paste these into their env
# var UI; VPS: place this file at /opt/commentcustomer/.env, owned by the
# `commentcustomer` user, mode 600).
#
# Lines starting with `#` are comments. Required vars are marked [REQUIRED].
###############################################################################

# ----- [REQUIRED] Core ------------------------------------------------------

# PostgreSQL connection string. Neon, Supabase, CockroachDB, or local PG.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Random 64-char hex string. Generate with:  openssl rand -hex 32
SESSION_SECRET=replace_me_with_64_random_hex_chars

# Production mode (do not change unless developing locally)
NODE_ENV=production

# Port the Node process listens on. nginx will proxy 443 → this port.
PORT=5000

# Public-facing URL (no trailing slash). Used for absolute links in emails,
# Stripe redirects, OG tags, etc.
PUBLIC_URL=https://yourdomain.com


# ----- [OPTIONAL] Stripe (real payments) ------------------------------------
# Leave blank to keep "demo mode" — billing UI works but no real charges.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=


# ----- [OPTIONAL] Email (real outbound mail) --------------------------------
# Leave blank to log emails to console instead of sending.
# Supports SMTP (e.g. Resend, SendGrid, Mailgun, your own server).

EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=


# ----- [OPTIONAL] Error tracking --------------------------------------------
SENTRY_DSN=


# ----- [OPTIONAL] Cron security (Vercel only) -------------------------------
# Random string. If set, the cron endpoints require Authorization: Bearer <this>.
# Vercel sets this header automatically when you provide CRON_SECRET in their UI.
CRON_SECRET=
