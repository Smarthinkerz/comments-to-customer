{
  "version": 2,
  "buildCommand": "echo 'no build step — server.cjs is the entrypoint'",
  "installCommand": "npm install --omit=dev --no-audit --no-fund --ignore-scripts",
  "outputDirectory": null,
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/all" }
  ],
  "functions": {
    "api/all.js": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "commentcustomer-developer/**"
    },
    "api/cron/outbox.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/cron/maintenance.js": {
      "memory": 512,
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/cron/outbox",      "schedule": "0 0 * * *" },
    { "path": "/api/cron/maintenance", "schedule": "0 0 * * *" }
  ]
}
